{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "ai/project_context.xml",
    "style": "xml",
    "truncateBase64": false,
    "copyToClipboard": false,
    "directoryStructure": true
  },
  "include": [
    "**/*.py",
    "**/*.toml",
    "**/*.lock",
    "**/*.md",
    "**/*.yaml",
    "**/*.yml",
    "**/*.sql",
    "**/*.txt",
    "Dockerfile"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "ai",
      "**/__pycache__",
      "**/.venv",
      "**/.pytest_cache",
      "**/.ruff_cache",
      "**/.mypy_cache",
      "build",
      "dist",
      "repomix.config.json",
      "repomix-instruction.md"
    ]
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}